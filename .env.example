# Supabase — get from Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini — get from https://aistudio.google.com/apikey
# CRITICAL: No NEXT_PUBLIC_ prefix. Server-side only. Never expose to client.
GEMINI_API_KEY=

# App URL — used for OAuth redirect construction
NEXT_PUBLIC_SITE_URL=http://localhost:3000
